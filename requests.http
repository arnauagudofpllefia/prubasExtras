### ================================
### PETICIONES DE AUTENTICACIÓN
### ================================

### POST - Registro de nuevo usuario (imagen obligatoria)
POST {{baseUrl}}/api/auth/registro
Content-Type: multipart/form-data; boundary=----AstroBoundary

------AstroBoundary
Content-Disposition: form-data; name="email"

cervezero@test.com
------AstroBoundary
Content-Disposition: form-data; name="password"

password123
------AstroBoundary
Content-Disposition: form-data; name="imatge"; filename="avatar-usuario.jpg"
Content-Type: image/jpeg

< ./uploads-proves/avatar-usuario.jpg
------AstroBoundary--

### POST - Registro de otro usuario (imagen obligatoria)
POST {{baseUrl}}/api/auth/registro
Content-Type: multipart/form-data; boundary=----AstroBoundary

------AstroBoundary
Content-Disposition: form-data; name="email"

admin@test.com
------AstroBoundary
Content-Disposition: form-data; name="password"

password123
------AstroBoundary
Content-Disposition: form-data; name="imatge"; filename="avatar-admin.jpg"
Content-Type: image/jpeg

< ./uploads-proves/avatar-admin.jpg
------AstroBoundary--

### POST - Login
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "cervezero@test.com",
  "password": "password123"
}

### POST - Login admin (después de promoverlo)
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "admin@api.com",
  "password": "admin123"
}

### GET - Ver perfil (requiere token)
GET {{baseUrl}}/api/auth/perfil
Authorization: Bearer {{userToken}}

### PUT - Actualizar perfil (requiere token)
PUT {{baseUrl}}/api/auth/perfil
Content-Type: application/json
Authorization: Bearer {{userToken}}

{
  "email": "usuario.actualizado@test.com",
  "password": "nuevopassword456"
}

### PATCH - Cambiar rol de usuario (solo admin) -> 200
PATCH {{baseUrl}}/api/auth/usuaris/{{userId}}/rol
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{
  "rol": "editor"
}

### PATCH - Cambiar rol con token de usuario -> 403
PATCH {{baseUrl}}/api/auth/usuaris/{{userId}}/rol
Content-Type: application/json
Authorization: Bearer {{userToken}}

{
  "rol": "admin"
}

### GET - Listar usuarios autenticados (solo admin) -> 200
GET {{baseUrl}}/api/auth/usuaris
Authorization: Bearer {{adminToken}}

### GET - Listar usuarios con token de usuario -> 403
GET {{baseUrl}}/api/auth/usuaris
Authorization: Bearer {{userToken}}

### ================================
### PETICIONES DE CERVEZAS
### ================================

### GET - Obtener todas las cervezas (solo admin)
GET {{baseUrl}}/api/cervezas
Authorization: Bearer {{adminToken}}

### GET - Obtener todas las cervezas sin token -> 401
GET {{baseUrl}}/api/cervezas

### POST - Crear cerveza con usuario normal -> 403
POST {{baseUrl}}/api/cervezas
Content-Type: multipart/form-data; boundary=----AstroBoundary
Authorization: Bearer {{userToken}}

------AstroBoundary
Content-Disposition: form-data; name="nombre"

Cerveza sin permiso
------AstroBoundary
Content-Disposition: form-data; name="precio"

3.50
------AstroBoundary
Content-Disposition: form-data; name="graduacion"

4.8
------AstroBoundary
Content-Disposition: form-data; name="tipo"

Lager
------AstroBoundary
Content-Disposition: form-data; name="descripcion"

Rubia ligera para consumo diario
------AstroBoundary
Content-Disposition: form-data; name="imatge"; filename="cerveza.jpg"
Content-Type: image/jpeg

< ./uploads-proves/cerveza.jpg
------AstroBoundary--

### POST - Crear cerveza con admin -> 201
POST {{baseUrl}}/api/cervezas
Content-Type: multipart/form-data; boundary=----AstroBoundary
Authorization: Bearer {{adminToken}}

------AstroBoundary
Content-Disposition: form-data; name="nombre"

Mahou Clasica
------AstroBoundary
Content-Disposition: form-data; name="precio"

3.50
------AstroBoundary
Content-Disposition: form-data; name="graduacion"

4.6
------AstroBoundary
Content-Disposition: form-data; name="tipo"

Lager
------AstroBoundary
Content-Disposition: form-data; name="descripcion"

Cerveza suave y refrescante
------AstroBoundary
Content-Disposition: form-data; name="imatge"; filename="mahou.jpg"
Content-Type: image/jpeg

< ./uploads-proves/mahou.jpg
------AstroBoundary--

### PUT - Actualizar cerveza (solo admin)
PUT {{baseUrl}}/api/cervezas/ID_CERVEZA
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{
  "nombre": "Corona actualizada",
  "precio": 4.50,
  "graduacion": 4.9,
  "tipo": "Lager Premium",
  "descripcion": "Version actualizada con sabor mas intenso"
}

### DELETE - Eliminar cerveza (solo admin)
DELETE {{baseUrl}}/api/cervezas/ID_CERVEZA
Authorization: Bearer {{adminToken}}

### GET - Obtener cerveza por ID (solo admin, cambiar el ID)
GET {{baseUrl}}/api/cervezas/ID_CERVEZA
Authorization: Bearer {{adminToken}}

### GET - Obtener cerveza con token usuario -> 403
GET {{baseUrl}}/api/cervezas/ID_CERVEZA
Authorization: Bearer {{userToken}}

### PATCH - Subir imagen a cerveza (solo admin, multipart/form-data)
PATCH {{baseUrl}}/api/cervezas/{{cervezaId}}/imatge
Authorization: Bearer {{adminToken}}
Content-Type: multipart/form-data; boundary=----AstroBoundary

------AstroBoundary
Content-Disposition: form-data; name="imatge"; filename="foto-prova.jpg"
Content-Type: image/jpeg

< ./uploads-proves/foto-prova.jpg
------AstroBoundary--

### PATCH - Subir imagen con token usuario -> 403
PATCH {{baseUrl}}/api/cervezas/{{cervezaId}}/imatge
Authorization: Bearer {{userToken}}
Content-Type: multipart/form-data; boundary=----AstroBoundary

------AstroBoundary
Content-Disposition: form-data; name="imatge"; filename="foto-prova.jpg"
Content-Type: image/jpeg

< ./uploads-proves/foto-prova.jpg
------AstroBoundary--

### GET - Ver imagen subida por URL publica
GET {{baseUrl}}/uploads/{{uploadedImage}}

