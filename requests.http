### ================================
### PETICIONES DE AUTENTICACIÓN
### ================================

### POST - Registro de nuevo usuario
POST {{baseUrl}}/api/auth/registro
Content-Type: application/json

{
  "email": "usuario@test.com",
  "password": "password123"
}

### POST - Registro de otro usuario
POST {{baseUrl}}/api/auth/registro
Content-Type: application/json

{
  "email": "admin@test.com",
  "password": "password123"
}

### POST - Login
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "usuario@test.com",
  "password": "password123"
}

### POST - Login admin (después de promoverlo)
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "email": "admin@api.com",
  "password": "admin123"
}

### GET - Ver perfil (requiere token)
GET {{baseUrl}}/api/auth/perfil
Authorization: Bearer {{userToken}}

### PUT - Actualizar perfil (requiere token)
PUT {{baseUrl}}/api/auth/perfil
Content-Type: application/json
Authorization: Bearer {{userToken}}

{
  "email": "usuario.actualizado@test.com",
  "password": "nuevopassword456"
}

### PATCH - Cambiar rol de usuario (solo admin) -> 200
PATCH {{baseUrl}}/api/auth/usuaris/{{userId}}/rol
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{
  "rol": "admin"
}

### PATCH - Cambiar rol con token de usuario -> 403
PATCH {{baseUrl}}/api/auth/usuaris/{{userId}}/rol
Content-Type: application/json
Authorization: Bearer {{userToken}}

{
  "rol": "admin"
}

### ================================
### PETICIONES DE CERVEZAS
### ================================

### GET - Obtener todas las cervezas (autenticado)
GET {{baseUrl}}/api/cervezas
Authorization: Bearer {{userToken}}

### GET - Obtener todas las cervezas sin token -> 401
GET {{baseUrl}}/api/cervezas

### POST - Crear cerveza con usuario normal -> 403
POST {{baseUrl}}/api/cervezas
Content-Type: application/json
Authorization: Bearer {{userToken}}

{
  "nombre": "Cerveza sin permiso",
  "precio": 3.50,
  "graduacion": 4.8,
  "tipo": "Lager",
  "descripcion": "Rubia ligera para consumo diario"
}

### POST - Crear cerveza con admin -> 201
POST {{baseUrl}}/api/cervezas
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{
  "nombre": "Mahou Clásica",
  "precio": 3.50,
  "graduacion": 4.6,
  "tipo": "Lager",
  "descripcion": "Cerveza suave y refrescante"
}

### PUT - Actualizar cerveza (solo admin)
PUT {{baseUrl}}/api/cervezas/ID_CERVEZA
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{
  "nombre": "Corona actualizada",
  "precio": 4.50,
  "graduacion": 4.9,
  "tipo": "Lager Premium",
  "descripcion": "Version actualizada con sabor mas intenso"
}

### DELETE - Eliminar cerveza (solo admin)
DELETE {{baseUrl}}/api/cervezas/ID_CERVEZA
Authorization: Bearer {{adminToken}}

### GET - Obtener cerveza por ID (cambiar el ID)
GET {{baseUrl}}/api/cervezas/ID_CERVEZA
Authorization: Bearer {{userToken}}

### PATCH - Subir imagen a cerveza (solo admin, multipart/form-data)
PATCH {{baseUrl}}/api/cervezas/{{cervezaId}}/imatge
Authorization: Bearer {{adminToken}}
Content-Type: multipart/form-data; boundary=----AstroBoundary

------AstroBoundary
Content-Disposition: form-data; name="imatge"; filename="foto-prova.jpg"
Content-Type: image/jpeg

< ./uploads-proves/foto-prova.jpg
------AstroBoundary--

### PATCH - Subir imagen con token usuario -> 403
PATCH {{baseUrl}}/api/cervezas/{{cervezaId}}/imatge
Authorization: Bearer {{userToken}}
Content-Type: multipart/form-data; boundary=----AstroBoundary

------AstroBoundary
Content-Disposition: form-data; name="imatge"; filename="foto-prova.jpg"
Content-Type: image/jpeg

< ./uploads-proves/foto-prova.jpg
------AstroBoundary--

### GET - Ver imagen subida por URL publica
GET {{baseUrl}}/uploads/{{uploadedImage}}

### ================================
### PETICIONES DE VINOS
### ================================

### GET - Obtener todos los vinos (autenticado)
GET {{baseUrl}}/api/vinos
Authorization: Bearer {{userToken}}

### POST - Crear nuevo vino con usuario normal -> 403
POST {{baseUrl}}/api/vinos
Content-Type: application/json
Authorization: Bearer {{userToken}}

{
  "nombre": "Vino Tinto Reserva",
  "precio": 15.50,
  "graduacion": 13.5,
  "tipo": "Tinto",
  "descripcion": "Reserva con notas de roble"
}

### POST - Crear nuevo vino con admin -> 201
POST {{baseUrl}}/api/vinos
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{
  "nombre": "Vino Blanco Fresco",
  "precio": 12.00,
  "graduacion": 11.5,
  "tipo": "Blanco",
  "descripcion": "Vino afrutado ideal para pescado"
}

### GET - Obtener vino por ID (cambiar el ID)
GET {{baseUrl}}/api/vinos/ID_VINO
Authorization: Bearer {{userToken}}

### PUT - Actualizar vino (cambiar el ID)
PUT {{baseUrl}}/api/vinos/ID_VINO
Content-Type: application/json
Authorization: Bearer {{adminToken}}

{
  "nombre": "Vino Tinto Premium",
  "precio": 18.00,
  "graduacion": 14.0,
  "tipo": "Tinto Crianza",
  "descripcion": "Tinto premium de cuerpo medio"
}

### DELETE - Eliminar vino (cambiar el ID)
DELETE {{baseUrl}}/api/vinos/ID_VINO
Authorization: Bearer {{adminToken}}
